# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== CORS =====
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===== PostgreSQL =====
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_postgres_password
PGDATABASE=studywise_db
PGSSL=false

# Optional connection string (leave commented)
# DATABASE_URL=postgres://postgres:your_postgres_password@localhost:5432/studywise_db

# ===== JWT =====
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ===== bcrypt =====
BCRYPT_SALT_ROUNDS=10

# ===== OpenAI =====
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ===== OAuth =====
# Where the backend redirects the browser AFTER a successful OAuth login.
# Must be your frontend origin (no trailing slash).
FRONTEND_URL=http://localhost:5173
# Public base URL of THIS backend — used to build the OAuth callback URL
# that you register with Google / GitHub.  In production use your HTTPS URL.
OAUTH_CALLBACK_BASE_URL=http://localhost:5000

# Google — https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI:  {OAUTH_CALLBACK_BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers  (New OAuth App)
#   Authorization callback URL:  {OAUTH_CALLBACK_BASE_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=