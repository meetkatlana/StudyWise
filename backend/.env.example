# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== CORS =====
# Comma-separated list of allowed origins (use * for all in dev)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===== PostgreSQL =====
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=studywise
# Optional single connection string (overrides individual vars if set)
# DATABASE_URL=postgres://user:pass@localhost:5432/studywise
PGSSL=false

# ===== JWT =====
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ===== bcrypt =====
BCRYPT_SALT_ROUNDS=10